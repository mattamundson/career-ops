pnpm run secrets:check

# Regen dashboard.html when tracked dashboard inputs are staged. The primary
# data sources (applications.md, pipeline.md, scan-history.tsv) are gitignored
# and local-only — Matt regenerates via `pnpm run dashboard` when those
# change. This hook handles the tracked inputs:
#   - data/responses.md  (tracked response log)
#   - dashboard.html     (staging a manual edit; hook overwrites with canonical)
#   - scripts/generate-dashboard.mjs (generator itself)
#   - scripts/lib/{career-data,scoring-core,profile-location-config,source-labels}.mjs (deps)
AFFECTS_DASHBOARD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(data/responses\.md|dashboard\.html|scripts/generate-dashboard\.mjs|scripts/lib/(career-data|scoring-core|profile-location-config|source-labels)\.mjs)$' || true)
if [ -n "$AFFECTS_DASHBOARD" ]; then
  echo "[pre-commit] dashboard-affecting file staged — refreshing dashboard.html"
  node scripts/generate-dashboard.mjs > /dev/null || {
    echo "[pre-commit] dashboard regen failed — aborting commit"
    exit 1
  }
  if ! git diff --quiet dashboard.html 2>/dev/null; then
    git add dashboard.html
    echo "[pre-commit] dashboard.html refreshed in this commit"
  fi
fi
